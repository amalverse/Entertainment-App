# MongoDB Configuration
# Get your MongoDB URI from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?appName=AppName

# JWT Secret Key
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Server Port
PORT=5000

# Email Configuration (for sending emails)
# Use Gmail App Password or other email service credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Google OAuth Configuration (Simplified - No Passport!)
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a new project in Google Cloud Console
# 2. Create OAuth 2.0 credentials
# 3. Add Authorized JavaScript origins: http://localhost:5173, http://localhost:5000
# 4. Authorized redirect URIs can be left empty or set to: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL for OAuth redirects
# Update this based on your frontend development server
FRONTEND_URL=http://localhost:5173

# Backend URL for OAuth callbacks and Swagger docs
# Update this based on your deployed backend server (Render, Vercel, etc.)
BACKEND_URL=http://localhost:5000
